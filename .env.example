# ─── Turso (orders + live rate) ─────────────────────────────────────────────
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Dev fallback: GHS per 1 RMB if app_settings has no rate yet
DEFAULT_EXCHANGE_RATE=

# Protect /admin/orders and GET/PATCH /api/admin/orders (x-admin-key header)
ADMIN_ORDERS_KEY=

# ─── Rate portal (5 taps on live rate on home — admins only) ─────────────────
RATE_PORTAL_USERNAME=
RATE_PORTAL_PASSWORD=
RATE_ADMIN_SESSION_SECRET=

# ─── Airtable (user sign-up / login only) ───────────────────────────────────
AIRTABLE_BASE_ID=
AIRTABLE_PERSONAL_ACCESS_TOKEN=

# ─── NextAuth (sign-in / dashboard sessions) ────────────────────────────────
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=

# Gmail (app password): password reset + new-order alerts to admin
EMAIL_USER=
EMAIL_PASSWORD=
# Where to send "new purchase submitted" emails (your ops inbox)
ADMIN_NOTIFY_EMAIL=
